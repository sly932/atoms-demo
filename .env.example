# ---- LLM (SiliconFlow, OpenAI-compatible) ----
# Get a key at https://siliconflow.cn  (or .com global)
SILICONFLOW_API_KEY=
# Endpoint base (no trailing /chat/completions)
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# Model id on SiliconFlow
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V4-Pro

# ---- Database (libSQL / Turso) ----
# Local dev: a file URL works out of the box, no account needed.
#   DATABASE_URL=file:./data/atoms.db
# Production (Vercel): create a free DB at https://turso.tech and paste:
#   DATABASE_URL=libsql://<your-db>.turso.io
#   DATABASE_AUTH_TOKEN=<token from `turso db tokens create`>
DATABASE_URL=file:./data/atoms.db
DATABASE_AUTH_TOKEN=

# Secret used to sign the session cookie (any long random string)
SESSION_SECRET=change-me-to-a-long-random-string
